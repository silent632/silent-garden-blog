---
import { cn } from 'astro-pure/utils'

const { class: className, title } = Astro.props
---

<section class={cn('flex flex-col gap-y-4 md:flex-row md:gap-y-0', className)}>
  <div class='home-section-title text-xl font-semibold md:min-w-38 md:pe-2'>
    <h2>{title}</h2>
  </div>
  <div class='home-section-body flex flex-1 flex-col gap-y-2.5'>
    <slot />
  </div>
</section>

<style>
  section {
    border: none;
    border-radius: 0.95rem;
    background-color: transparent;
    box-shadow: none;
    padding: 0.95rem 1rem 1.05rem;
    transition: background-color var(--motion-fast) var(--motion-ease);
  }

  .home-section-title h2 {
    display: inline-block;
  }

  .home-section-title {
    padding-inline-start: 0.35rem;
  }

  .home-section-body {
    line-height: 1.82;
  }

  @media (min-width: 768px) {
    section {
      padding: 1rem 1.1rem 1.08rem;
    }
    .home-section-title {
      padding-top: 0.1rem;
      padding-inline-start: 0.55rem;
    }
  }

  @media (max-width: 640px) {
    section {
      border-radius: 0.88rem;
      padding: 0.86rem 0.82rem 0.94rem;
    }
    .home-section-body {
      line-height: 1.76;
    }
  }
</style>
