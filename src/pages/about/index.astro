---
import links from 'public/links.json'
import config from 'virtual:config'

import { Comment } from 'astro-pure/advanced'
import { Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import FriendList from '@/components/links/FriendList.astro'
import { CardList } from 'astro-pure/user'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'links', text: 'Links' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]

const { friends } = links
const linksConf = config.integ.links
const applyTipItems = linksConf.applyTip.filter(({ val }) => String(val || '').trim())
---

<PageLayout title='About' {headings} info='/about'>
  <p>Welcome to Silent's Garden.</p>
  <p style='line-height: 2;'>
    This is my digital garden.<br />
    I believe in long-termism, and I write about thoughts, reading, and life.<br />
    Hope you find something interesting here.
  </p>

  <p>
    <Spoiler>Easter egg: hope you have a wonderful day.</Spoiler>
  </p>

  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>Reading, writing, and long-term personal knowledge management.</li>
    <li>Building small tools that make daily work quieter and more reliable.</li>
    <li>Recording how ideas, books, and projects compound over time.</li>
  </ul>

  <h2 id='links'>Links</h2>
  <p>Link exchange is welcome:</p>

  <FriendList list={friends[0]} />

  <!-- apply-links -->
  <p>Apply for link exchange:</p>
  {
    applyTipItems.length > 0 ? (
      <>
        <p>Site profile (click to copy):</p>
        <blockquote class='not-prose grid grid-cols-[auto_1fr] gap-x-2 break-words border-s-4 ps-4'>
          {
            applyTipItems.map(({ name, val }) => (
              <>
                <span class='text-end'>{name}:</span>
                <samp class='cursor-pointer' data-copy-value={val}>
                  {val}
                </samp>
              </>
            ))
          }
        </blockquote>
      </>
    ) : (
      <p class='text-muted-foreground'>Set `SITE_URL` to publish the site profile for link exchange.</p>
    )
  }

  <br />

  <CardList
    title='Before applying, please make sure:'
    list={[
      { title: '1. You have added this site to your links page.' },
      { title: '2. Your site is online and accessible.' },
      { title: '3. Content does not violate laws or regulations.' }
    ]}
  />

  <h2 id='about-blog'>About this blog</h2>
  <p>
    Built with Astro and the Pure theme, with content synced from local writing workflows.<br />
    Keep recording, keep compounding.
  </p>

  <Collapse title='Site Logbook'>
    <Timeline events={linksConf.logbook} />
  </Collapse>

  <Comment slot='bottom' />
</PageLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-copy-value]').forEach((el) => {
    el.addEventListener('click', () => {
      const value = el.getAttribute('data-copy-value') || ''
      navigator.clipboard.writeText(value)
      document.dispatchEvent(
        new CustomEvent('toast', { detail: { message: `Copied "${value}"` } })
      )
    })
  })
</script>
