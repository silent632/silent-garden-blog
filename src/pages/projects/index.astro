---
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import { theme } from '../../site.config'
import syncedProjects from '../../data/projects/projects.json'

const headings = [
  { depth: 2, slug: 'my-projects', text: 'Project List' },
  { depth: 2, slug: 'sponsorship', text: 'Support' }
]

const projectList = Array.isArray(syncedProjects) ? syncedProjects : []

function resolveGithubUsername(input: string) {
  const raw = input.trim()
  if (!raw) return ''
  if (!raw.includes('github.com')) return raw.replace(/^@/, '')
  try {
    const parsed = new URL(raw)
    const [firstSegment = ''] = parsed.pathname.split('/').filter(Boolean)
    return firstSegment.replace(/^@/, '')
  } catch {
    return raw.replace(/^https?:\/\/(www\.)?github\.com\//, '').split('/')[0]?.replace(/^@/, '') || ''
  }
}

const githubProfileUrl = theme.footer?.social?.github || ''
const githubUsername = resolveGithubUsername(githubProfileUrl)
const githubChartUrl = githubUsername
  ? `https://ghchart.rshah.org/40814F/${githubUsername}`
  : ''
---

<PageLayout
  title='Projects'
  {headings}
  info={{
    slug: '/projects',
    hideComment: false
  }}
>
  <p>GitHub Activity:</p>
  {githubChartUrl ? (
    <p>
      <a href={githubProfileUrl || `https://github.com/${githubUsername}`} target='_blank' rel='noreferrer'>
        <img src={githubChartUrl} alt={`${githubUsername} github activities`} loading='lazy' />
      </a>
    </p>
  ) : (
    <p class='text-muted-foreground'>GitHub account is not configured yet.</p>
  )}
  <p>A collection of my projects.</p>

  <h2 id='my-projects'>Project List</h2>

  {projectList.length > 0 ? (
    <ProjectSection projects={projectList} />
  ) : (
    <p class='text-muted-foreground'>No projects published yet.</p>
  )}

  <h2 id='sponsorship'>Support</h2>
  <p>If you like my content, feel free to support this site.</p>
  {/* Add your sponsorship QR code
  <Sponsorship
    methods={[
      { name: 'WeChat', icon: 'wechat-pay', image: wechat },
    ]}
  />
  */}
</PageLayout>
