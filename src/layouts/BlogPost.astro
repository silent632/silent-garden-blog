---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import { Comment, MediumZoom } from 'astro-pure/advanced'
import { ArticleBottom, Copyright, PageInfo, TOC } from 'astro-pure/components/pages'
import { FormattedDate, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'
import { integ } from '@/site-config'
import { processTags } from '@/utils/formatTag'

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props

const {
  description,
  heroImage,
  publishDate,
  title,
  updated,
  draft: isDraft,
  comment: enableComment
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : '/images/social-card.png'
const articleDate = updated?.toISOString() ?? publishDate?.toISOString() ?? new Date().toISOString()
const primaryColor = data.heroImage?.color ?? '#64879A'
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back='/blog'
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <div class='article-info article-hero max-lg:mx-auto' slot='header'>
    <h1 class='article-title text-2xl font-semibold sm:mb-1 sm:text-3xl'>
      {title}
    </h1>

    <div class='article-meta-row mt-2 flex flex-wrap gap-x-3 gap-y-2 text-base leading-7 text-muted-foreground'>
      {data.draft ? <span class='article-draft-pill'>(Draft)</span> : null}
      {/* Article date */}
      <div class='article-meta-item'>
        <Icon name='calendar' class='size-5' />
        {publishDate && <FormattedDate class='font-sans' date={publishDate} dateTimeOptions={{ month: 'short' }} />}
        {updated && (
          <div class='flex items-center gap-1'>
            <span> / </span>
            <span>
              Update
              <FormattedDate
                class='font-sans'
                date={updated}
                dateTimeOptions={{ month: 'short' }}
              />
            </span>
          </div>
        )}
      </div>
      {/* Times read */}
      <div class='article-meta-item'>
        <Icon name='time' class='size-5' />
        {remarkPluginFrontmatter.minutesRead}
      </div>
      {data.language && (
        <span class='article-meta-item'>
          <Icon name='earth' class='size-5' />
          {data.language}
        </span>
      )}
      {!!data.tags?.length && (
        <span class='article-meta-item article-meta-tags'>
          <Icon name='hashtag' class='size-5' />
          {processTags(data.tags).map((tag: string, i: number) => (
            <div>
              <a
                aria-label={`View more blogs with the tag ${tag}`}
                class='article-tag-link'
                data-pagefind-filter='tag'
                href={`/tags/${tag}`}
              >
                {tag}
              </a>
              {i < processTags(data.tags).length - 1 && '/'} 
            </div>
          ))}
        </span>
      )}
    </div>

    <div class='mt-5'>
      <div class='article-description'>
        {description}
      </div>
      {!data.draft && data.comment && <PageInfo class='mt-2' />}
    </div>
  </div>

  {/* Dividing line */}
  <div class='article-divider mt-2 w-1/2 max-lg:mx-auto sm:mt-3 sm:w-1/3' slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <Copyright {data} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    {/* Comment */}
    {!isDraft && enableComment && <Comment class='mt-3 sm:mt-6' />}
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}

<style>
  h1,
  h2,
  h3,
  h4,
  h5 {
    font-family: 'Noto Serif SC', 'Songti SC', 'STSong', serif;
  }

  .article-hero {
    border: 1px solid hsl(var(--border) / 0.88);
    border-radius: 1rem;
    background-image: linear-gradient(
      145deg,
      hsl(var(--card) / 0.94),
      hsl(var(--youth-accent) / 0.08)
    );
    box-shadow: var(--surface-shadow-sm);
    padding: 1.1rem 1.2rem;
  }

  .article-title {
    color: hsl(var(--foreground) / 0.99);
    letter-spacing: 0.012em;
    line-height: 1.32;
  }

  .article-meta-row {
    font-family: var(--sl-font-sans);
  }

  .article-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border-radius: 9999px;
    background-color: hsl(var(--muted) / 0.58);
    color: hsl(var(--muted-foreground) / 0.95);
    padding: 0.1rem 0.52rem;
  }

  .article-meta-tags {
    flex-wrap: wrap;
  }

  .article-tag-link {
    color: hsl(var(--foreground) / 0.84);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color var(--motion-fast) var(--motion-ease),
      border-color var(--motion-fast) var(--motion-ease);
  }

  .article-tag-link:hover,
  .article-tag-link:focus-visible {
    color: hsl(var(--youth-accent-ink));
    border-bottom-color: hsl(var(--youth-accent-ink) / 0.7);
    outline: none;
  }

  .article-draft-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    background-color: hsl(var(--destructive) / 0.14);
    color: hsl(var(--destructive) / 0.9);
    font-family: var(--sl-font-sans);
    padding: 0.1rem 0.55rem;
  }

  .article-description {
    border-radius: 0.88rem;
    border: 1px solid hsl(var(--border) / 0.8);
    background-image: linear-gradient(
      145deg,
      hsl(var(--card) / 0.92),
      hsl(var(--youth-accent) / 0.11)
    );
    color: hsl(var(--foreground) / 0.95);
    font-size: 1.14rem;
    line-height: 1.86;
    padding: 0.9rem 1rem;
  }

  :global(#content.prose) {
    color: hsl(var(--foreground) / 0.95);
    font-size: 1.14rem;
    line-height: 1.95;
  }

  :global(#content.prose p),
  :global(#content.prose li),
  :global(#content.prose blockquote) {
    color: hsl(var(--foreground) / 0.93);
    font-size: 1.22rem;
    line-height: 2.02;
  }

  :global(#content.prose li p) {
    font-size: inherit;
    line-height: inherit;
  }

  :global(#content.prose ol > li::marker),
  :global(#content.prose ul > li::marker) {
    font-size: 1.05em;
  }

  :global(#content.prose strong) {
    color: hsl(var(--foreground));
  }

  :global(#content.prose h1),
  :global(#content.prose h2),
  :global(#content.prose h3),
  :global(#content.prose h4),
  :global(#content.prose h5),
  :global(#content.prose h6) {
    color: hsl(var(--foreground) / 0.99);
  }

  :global(#content.prose a) {
    color: hsl(var(--primary) / 0.95);
    text-underline-offset: 0.18em;
  }

  .article-divider {
    border-top: 0;
    height: 1px;
    background-image: linear-gradient(
      90deg,
      hsl(var(--border) / 0),
      hsl(var(--border) / 0.9),
      hsl(var(--youth-accent) / 0.34),
      hsl(var(--border) / 0)
    );
  }

  @media (max-width: 640px) {
    .article-hero {
      border-radius: 0.9rem;
      padding: 0.95rem 0.95rem;
    }

    .article-title {
      letter-spacing: 0.008em;
    }

    .article-description {
      font-size: 1.08rem;
      line-height: 1.8;
    }

    :global(#content.prose) {
      font-size: 1.08rem;
      line-height: 1.88;
    }

    :global(#content.prose p),
    :global(#content.prose li),
    :global(#content.prose blockquote) {
      font-size: 1.12rem;
      line-height: 1.9;
    }
  }

  :global(.dark) .article-hero {
    border-color: hsl(var(--border) / 0.78);
    background-image: linear-gradient(
      150deg,
      hsl(var(--card) / 0.78),
      hsl(var(--youth-accent) / 0.18)
    );
  }

  :global(.dark) .article-meta-item {
    background-color: hsl(var(--muted) / 0.7);
    color: hsl(var(--muted-foreground) / 0.95);
  }

  :global(.dark) .article-description {
    border-color: hsl(var(--border) / 0.7);
    background-image: linear-gradient(
      145deg,
      hsl(var(--card) / 0.72),
      hsl(var(--youth-accent) / 0.22)
    );
    color: hsl(var(--foreground) / 0.95);
  }

  :global(.dark #content.prose) {
    color: hsl(var(--foreground) / 0.96);
  }

  :global(.dark #content.prose p),
  :global(.dark #content.prose li),
  :global(.dark #content.prose blockquote) {
    color: hsl(var(--foreground) / 0.94);
  }

  :global(.dark #content.prose strong),
  :global(.dark #content.prose h1),
  :global(.dark #content.prose h2),
  :global(.dark #content.prose h3),
  :global(.dark #content.prose h4),
  :global(.dark #content.prose h5),
  :global(.dark #content.prose h6) {
    color: hsl(var(--foreground) / 0.99);
  }

  :global(html:not(.dark)) .article-title {
    color: #0d0d0d;
  }

  :global(html:not(.dark)) .article-description {
    color: #171717;
  }

  :global(html:not(.dark)) .article-meta-row,
  :global(html:not(.dark)) .article-meta-item {
    color: #343434;
  }

  :global(html:not(.dark) #content.prose) {
    color: #171717;
  }

  :global(html:not(.dark) #content.prose p),
  :global(html:not(.dark) #content.prose li),
  :global(html:not(.dark) #content.prose blockquote) {
    color: #1d1d1d;
  }

  :global(html:not(.dark) #content.prose strong),
  :global(html:not(.dark) #content.prose h1),
  :global(html:not(.dark) #content.prose h2),
  :global(html:not(.dark) #content.prose h3),
  :global(html:not(.dark) #content.prose h4),
  :global(html:not(.dark) #content.prose h5),
  :global(html:not(.dark) #content.prose h6) {
    color: #101010;
  }

  :global(html:not(.dark) #content.prose a),
  :global(html:not(.dark)) .article-tag-link {
    color: #1f4a63;
  }

  :global(html:not(.dark)) .article-tag-link:hover,
  :global(html:not(.dark)) .article-tag-link:focus-visible {
    color: #16384d;
    border-bottom-color: rgb(22 56 77 / 0.5);
  }

</style>

